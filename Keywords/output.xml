// public functions
  /*-----------------------------------------------------*//**
   *  @brief  指定したAPI_URLへGETリクエストを行う
   *
   *  @param  [in]    url        : URL
   *
   *  @retval json               : リダイレクト先のURLが存在しない場合、
   *                               レスポンスをJSONで返す
   *
   *//*--------------------------------------------------------
   */
function uiGet(url) {
	return $.get('https://uf17-fdev.unifas.jp/UNIFAS/MS/webapi/v1/' + url)
		.then(function (json) {
			if (json.redirect) {
				document.location = json.redirect;
			} else {
				return json;
			}
		});
}
  /*-----------------------------------------------------*//**
   *  @brief  指定したAPI_URLへPOSTリクエストを行う
   *
   *  @param  [in]    url         : URL
   *  @param  [in]    data        : 送信するデータ
   *
   *  @retval json                : リダイレクト先のURLが存在しない場合、
   *                                レスポンスをJSONで返す
   *
   *//*--------------------------------------------------------
   */
function uiPost(url, data) {
	return $.post('https://uf17-fdev.unifas.jp/UNIFAS/MS/webapi/v1/' + url, data)
		.then(function (json) {
			if (json.redirect) {
				document.location = json.redirect;
			} else {
				return json;
			}
		});
}
  /*-----------------------------------------------------*//**
   *  @brief  指定したAPI_URLへPUTリクエストを行う
   *
   *  @param  [in]    url        : URL
   *  @param  [in]    data       : 送信するデータ
   *
   *  @retval json               : リダイレクト先のURLが存在しない場合、
   *                               レスポンスをJSONで返す
   *
   *//*--------------------------------------------------------
   */
function uiPut(url, data) {
	return $.ajax({
		url: 'https://uf17-fdev.unifas.jp/UNIFAS/MS/webapi/v1/' + url,
		type: 'POST',
		data: data,
		headers: {
			'X-HTTP-Method-Override': 'PUT'
		}
	}).then(function (json) {
		if (json.redirect) {
			document.location = json.redirect;
		} else {
			return json;
		}
	});
}
  /*-----------------------------------------------------*//**
   *  @brief  指定したAPI_URLへPATCHリクエストを行う
