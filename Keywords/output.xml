		}
	}).then(function (json) {
		if (json.redirect) {
			document.location = json.redirect;
		} else {
			return json;
		}
	});
}
  /*-----------------------------------------------------*//**
   *  @brief  指定したAPI_URLへDELETEリクエストを行う
   *
   *  @param  [in]    url        : URL
   *  @param  [in]    data       : 送信するデータ
