   *  @retval json               : リダイレクト先のURLが存在しない場合、
   *                               レスポンスをJSONで返す
   *
   *//*--------------------------------------------------------
   */
function uiDelete(url, data) {
	return $.ajax({
		url: 'https://uf17-fdev.unifas.jp/UNIFAS/MS/webapi/v1/' + url,
		type: 'POST',
		data: data,
		headers: {
			'X-HTTP-Method-Override': 'DELETE'
		},
		timeout: 0
	}).then(function (json) {
		if (json.redirect) {
			document.location = json.redirect;
		} else {
			return json;
		}
	});
}
